    DESC --> EDORG

    EDORG --> CAL
    EDORG --> TL1

    CAL --> DISCI
    CAL --> GRAD
    TL1 --> GRAD

    GRAD --> STAFF
    GRAD --> COH9
    GRAD --> STU
    GRAD --> CONT

    STAFF --> STAFFEDORG
    STU --> ENROLL
    CONT --> ENROLL

    STAFFEDORG --> STUDENTID
    COH9 --> COH14
    ENROLL --> STUDENTID
    ENROLL --> TL2
    ENROLL --> ATT
    ENROLL --> DIS14
    ENROLL --> ACADREC
    ENROLL --> ALTSUPP
    DISCI --> DIS14

    STUDENTID --> CONTUPD
    TL2 --> GRADE

    STAFFEDORG --> STAFFREM
    TL2 --> STAFFSEC
    COH14 --> STAFFCOH
    ACADREC --> TRANSCRIPT
    ALTSUPP --> TRANSCRIPT
    DIS14 --> DISACTION
